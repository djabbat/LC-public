# LongevityCommon — server-side .env for docker-compose-all.yml
# Copy this to ~/web/longevitycommon/.env on the server and fill in real values.
# DO NOT commit the actual .env file.
#
# Generate Phoenix secrets:
#   cd ~/Desktop/LongevityCommon/Ze/ze-web && mix phx.gen.secret
# (or any Phoenix project; output is a 64-char base-encoded string)

# Postgres for social layer
POSTGRES_PASSWORD=                           # 32+ char random; use `openssl rand -hex 24`

# Phoenix secret key bases (run `mix phx.gen.secret` 3 times)
ZE_WEB_SECRET_KEY_BASE=                      # 64 chars min
BIOSENSE_WEB_SECRET_KEY_BASE=                # 64 chars min
REALTIME_SECRET_KEY_BASE=                    # 64 chars min

# Public hostnames (must match nginx + DNS A-records)
ZE_PHX_HOST=ze.longevity.ge
BIOSENSE_PHX_HOST=biosense.longevity.ge
REALTIME_PHX_HOST=app.longevity.ge

# Logging
RUST_LOG=info
LONGEVITYCOMMON_VERSION=v5.6
