[Unit]
Description=AIM self-dev eval harness (one-shot)
Documentation=file:///home/oem/Desktop/LC/AIM/docs/AIM_FS/SPEC.md
After=network.target

[Service]
Type=oneshot
Environment=AIM_FS_ROOT=%h/.aim_fs
Environment=AIM_FS_TENANT=djabbat
ExecStart=/usr/local/bin/aim-self-dev-eval
StandardOutput=journal
StandardError=journal
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

[Install]
WantedBy=default.target
