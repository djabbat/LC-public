[Unit]
Description=AIM_FS nightly export + git commit
Documentation=file:///home/oem/Desktop/LC/AIM/docs/AIM_FS/SPEC.md
After=network.target

[Service]
Type=oneshot
Environment=AIM_FS_ROOT=%h/.aim_fs
Environment=AIM_FS_TENANT=djabbat
Environment=AIM_FS_EXPORT_DIR=%h/aim_fs_export
ExecStart=/usr/local/bin/aim-fs-export-commit
StandardOutput=journal
StandardError=journal
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7

[Install]
WantedBy=default.target
