[Unit]
Description=AIM daily eval harness run with regression alert
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
EnvironmentFile=-%h/.aim_env
WorkingDirectory=%h/Desktop/LC/AIM
ExecStart=%h/Desktop/LC/AIM/venv/bin/python -m scripts.auto_eval
StandardOutput=journal
StandardError=journal
