[Unit]
Description=AIM RAG (Rust :8771)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=oem
WorkingDirectory=/home/oem/Desktop/LC/AIM/rust-core
EnvironmentFile=-/home/oem/.aim_env
Environment="RUST_LOG=info"
Environment="AIM_ENV=prod"
ExecStart=/home/oem/Desktop/LC/AIM/rust-core/target/release/aim-rag
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/home/oem/Desktop/LC/AIM
PrivateTmp=true

[Install]
WantedBy=multi-user.target
