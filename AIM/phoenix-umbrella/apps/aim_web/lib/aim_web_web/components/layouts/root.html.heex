<!DOCTYPE html>
<html lang={Atom.to_string(assigns[:locale] || :en)} dir={if AimWeb.I18n.rtl?(assigns[:locale] || :en), do: "rtl", else: "ltr"} data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title><%= AimWeb.I18n.t("app.title", assigns[:locale] || :en) %></title>
    <link rel="icon" type="image/svg+xml"
          href="data:image/svg+xml;utf8,%3Csvg%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%20viewBox%3D%220%200%20100%20100%22%3E%3Ctext%20y%3D%22.9em%22%20font-size%3D%2290%22%3E%E2%8C%AC%3C/text%3E%3C/svg%3E" />

    <style>
      /* ── Body baseline (matches *.longevity.ge dark theme) ─────────────── */
      html { background: #0f1117; }
      body {
        margin: 0;
        background: #0f1117;
        color: #e0e3eb;
        font-family: Inter, -apple-system, BlinkMacSystemFont, system-ui, "Segoe UI", Roboto, sans-serif;
        font-size: 15px;
        line-height: 1.5;
      }
      a { color: #88a8ff; text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3, h4 { color: #fff; margin-top: 0; }
      h1 { font-size: 1.85rem; font-weight: 700; }
      h2 { font-size: 1.25rem; font-weight: 600; margin: 1.5rem 0 0.5rem; }
      h3 { font-size: 1.05rem; font-weight: 600; margin: 0; }

      /* ── eco-bar-injected — IDENTICAL to longevity.ge/eco-inject.js v=31 ── */
      .eco-bar-injected {
        position: sticky !important; top: 0 !important; z-index: 100 !important;
        background: rgba(6,8,15,0.97) !important;
        backdrop-filter: blur(8px) !important;
        border-bottom: 1px solid rgba(255,255,255,0.06) !important;
        font-family: Inter, -apple-system, system-ui, sans-serif !important;
        font-size: 15px !important; line-height: 1.4 !important;
        width: 100% !important; box-sizing: border-box !important; margin: 0 !important;
      }
      .eco-inner-i {
        max-width: 1100px !important; margin: 0 auto !important;
        padding: 12px 32px !important;
        display: flex !important; align-items: center !important;
        justify-content: space-between !important; gap: 16px !important;
        flex-wrap: wrap !important; box-sizing: border-box !important; width: 100% !important;
      }
      .eco-brand-i {
        font-weight: 700 !important; font-size: 15px !important;
        color: #fff !important; letter-spacing: -0.01em !important; line-height: 1.2 !important;
      }
      .eco-brand-i::before {
        content: "\25CF" !important; color: #4f46e5 !important;
        margin-right: 8px !important; font-size: 10px !important; vertical-align: middle !important;
      }
      .eco-nav-i {
        display: flex !important; gap: 2px !important; flex-wrap: wrap !important;
        align-items: center !important; font-size: 13px !important;
        background: transparent !important; border: none !important; position: static !important;
      }
      .eco-nav-i a {
        color: #cbd5e1 !important; padding: 6px 12px !important;
        border-radius: 6px !important; font-size: 13px !important; font-weight: 500 !important;
        transition: all 0.15s !important; text-decoration: none !important;
        line-height: 1.2 !important; background: transparent !important; border: none !important;
      }
      .eco-nav-i a:hover { background: rgba(255,255,255,0.08) !important; color: #fff !important; }
      .eco-nav-i a.active { background: #4f46e5 !important; color: #fff !important; }
      .eco-nav-i a.donate-cta {
        background: #dc2626 !important; color: #fff !important; font-weight: 600 !important;
        padding: 6px 14px !important; border-radius: 6px !important;
        box-shadow: 0 1px 3px rgba(220,38,38,0.4) !important;
      }
      .eco-nav-i a.donate-cta::before { content: "\2665 " !important; color: #fff !important; margin-right: 2px !important; }
      .theme-toggle-i {
        background: transparent !important; border: 1px solid rgba(255,255,255,0.35) !important;
        color: #fff !important; cursor: pointer !important; padding: 4px 10px !important;
        border-radius: 4px !important; font-size: 16px !important; margin-left: 12px !important;
        line-height: 1 !important;
      }
      .theme-toggle-i:hover { background: rgba(255,255,255,0.12) !important; }

      /* ── AIM-internal subnav ─────────────────────────────────────────── */
      .aim-subnav {
        max-width: 1100px;
        margin: 0 auto;
        padding: 10px 32px;
        display: flex;
        align-items: center;
        gap: 1rem;
        border-bottom: 1px solid #2a2f40;
      }
      .aim-subnav .brand {
        font-weight: 700;
        color: #fff;
        font-size: 1.05rem;
      }
      .aim-subnav .brand .logo { color: #4f46e5; margin-right: 0.4rem; }
      .aim-subnav nav { display: flex; gap: 0.4rem; flex-wrap: wrap; flex: 1; }
      .aim-subnav nav a {
        color: #cbd5e1;
        font-size: 13px;
        padding: 4px 10px;
        border-radius: 6px;
        font-weight: 500;
      }
      .aim-subnav nav a:hover { background: rgba(255,255,255,0.08); color: #fff; text-decoration: none; }
      .aim-subnav nav a.active { background: #1a2440; color: #fff; }
      .aim-subnav .lang-switcher select {
        background: #1a1d28; color: #e0e3eb;
        border: 1px solid #2a2f40; border-radius: 6px;
        padding: 4px 8px; font-size: 13px; cursor: pointer;
      }

      /* ── Page container ──────────────────────────────────────────────── */
      .aim-page { max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; }

      /* ── Landing ─────────────────────────────────────────────────────── */
      .aim-landing { max-width: 1100px; margin: 0 auto; padding: 1rem 1.5rem 4rem; }
      .hero {
        text-align: center;
        padding: 3rem 0 2.5rem;
        border-bottom: 1px solid #2a2f40;
      }
      .brand-mark { font-size: 4rem; color: #4f46e5; line-height: 1; margin-bottom: 0.5rem; }
      .hero h1 { font-size: 2.4rem; margin: 0.3rem 0 0.7rem; }
      .hero .tagline { color: #c8ccd5; max-width: 720px; margin: 0 auto 2rem; font-size: 1.05rem; }
      .cta-row { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }
      .cta {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        border-radius: 8px;
        background: #15171f;
        color: #e0e3eb;
        border: 1px solid #2a2f40;
        font-weight: 500;
        transition: transform 0.1s, border-color 0.15s;
      }
      .cta:hover { text-decoration: none; border-color: #88a8ff; transform: translateY(-1px); }
      .cta.primary { background: #4f46e5; color: #fff; border-color: #4f46e5; }
      .cta.primary:hover { background: #4338ca; border-color: #4338ca; }

      .features {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 1.2rem; margin: 2.5rem 0;
      }
      .feature {
        background: #15171f;
        border: 1px solid #2a2f40;
        border-radius: 12px;
        padding: 1.4rem;
      }
      .feature-icon { font-size: 1.7rem; margin-bottom: 0.6rem; }
      .feature p { color: #c8ccd5; margin: 0; font-size: 0.95rem; line-height: 1.5; }

      .quicknav {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1rem;
        margin-top: 2rem;
      }
      .quicknav .card {
        display: block;
        padding: 1.3rem;
        background: #15171f;
        border: 1px solid #2a2f40;
        border-radius: 12px;
        color: #e0e3eb;
        transition: border-color 0.15s, transform 0.1s;
      }
      .quicknav .card:hover {
        text-decoration: none;
        border-color: #88a8ff;
        transform: translateY(-1px);
      }
      .quicknav .card h3 { color: #fff; margin-bottom: 0.4rem; }
      .quicknav .card p { color: #c8ccd5; margin: 0; font-size: 0.9rem; }

      /* ── Dashboard ───────────────────────────────────────────────────── */
      .aim-dashboard { max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; }
      .aim-dashboard section { margin-bottom: 2rem; }
      .aim-dashboard ul { list-style: none; padding: 0; }
      .aim-dashboard li {
        padding: 0.6rem 0.9rem;
        background: #15171f;
        border: 1px solid #2a2f40;
        border-radius: 8px;
        margin-bottom: 0.4rem;
      }
      .status { padding: 0.2rem 0.55rem; border-radius: 999px; font-size: 0.8rem; font-weight: 600; }
      .status-ok, .status-starting { background: rgba(74,222,128,0.15); color: #4ade80; }
      .status-warning { background: rgba(251,191,36,0.18); color: #fbbf24; }
      .status-down, .status-critical { background: rgba(239,68,68,0.15); color: #ef4444; }

      /* ── Drug interactions ───────────────────────────────────────────── */
      .aim-drug-check { max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; }
      .aim-drug-check form {
        background: #15171f; padding: 1.2rem;
        border-radius: 10px; border: 1px solid #2a2f40;
        margin-bottom: 1.5rem;
      }
      .aim-drug-check textarea {
        width: 100%;
        background: #1a1d28; color: #e0e3eb;
        border: 1px solid #2a2f40; border-radius: 6px;
        padding: 0.65rem; font-family: inherit; font-size: 0.95rem;
        margin-bottom: 0.7rem; resize: vertical;
      }
      .aim-drug-check .actions { display: flex; gap: 0.6rem; }
      .aim-drug-check button {
        padding: 0.55rem 1.2rem; border-radius: 6px;
        border: 1px solid #2a2f40; background: #15171f;
        color: #e0e3eb; cursor: pointer; font-weight: 500;
      }
      .aim-drug-check button[type="submit"] { background: #4f46e5; color: #fff; border-color: #4f46e5; }
      .aim-drug-check button:disabled { opacity: 0.5; cursor: not-allowed; }
      .drug-list { list-style: none; padding: 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
      .drug-list li {
        background: #15171f; border: 1px solid #2a2f40;
        padding: 0.3rem 0.7rem; border-radius: 999px; font-size: 0.88rem;
      }
      .findings table { width: 100%; border-collapse: collapse; margin-top: 0.7rem; }
      .findings th, .findings td { text-align: left; padding: 0.5rem 0.7rem; border-bottom: 1px solid #2a2f40; }
      .findings th { color: #c8ccd5; font-weight: 500; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.04em; }
      .sev-major { color: #ef4444; }
      .sev-moderate { color: #fbbf24; }
      .sev-minor { color: #c8ccd5; }
      .report { background: #15171f; border: 1px solid #2a2f40; border-radius: 8px; padding: 1rem; white-space: pre-wrap; font-family: ui-monospace, "SF Mono", Monaco, monospace; font-size: 0.85rem; }

      /* ── Settings ────────────────────────────────────────────────────── */
      .aim-settings { max-width: 1100px; margin: 2rem auto; padding: 0 1.5rem; }
      .aim-settings .hint { color: #c8ccd5; font-size: 0.9rem; max-width: 720px; }
      .provider-list { list-style: none; padding: 0; }
      .provider-list > li {
        display: flex; align-items: center; gap: 0.8rem;
        padding: 0.7rem; background: #15171f;
        border: 1px solid #2a2f40; border-radius: 8px;
        margin-bottom: 0.5rem; flex-wrap: wrap;
      }
      .provider-name { min-width: 110px; font-weight: 500; }
      .key-form { display: flex; gap: 0.5rem; flex: 1; }
      .key-form input[type="password"] {
        flex: 1; background: #1a1d28; color: #e0e3eb;
        border: 1px solid #2a2f40; border-radius: 6px;
        padding: 0.4rem 0.6rem; font-family: ui-monospace, monospace;
      }
      .key-form button, .clear, .clear-all {
        padding: 0.4rem 0.9rem; background: #1a1d28;
        color: #e0e3eb; border: 1px solid #2a2f40;
        border-radius: 6px; cursor: pointer; font-size: 0.88rem;
      }
      .clear { color: #c8ccd5; }
      .clear-all { margin-top: 0.8rem; color: #ef4444; border-color: #ef4444; }
      .status-error { padding: 0.5rem 0.8rem; border-radius: 6px; background: rgba(239,68,68,0.15); color: #ef4444; }

      /* ── Footer ──────────────────────────────────────────────────────── */
      .aim-footer {
        max-width: 1100px;
        margin: 3rem auto 1.5rem;
        padding: 1.5rem 1.5rem 0;
        border-top: 1px solid #2a2f40;
        color: #c8ccd5;
        font-size: 0.85rem;
        text-align: center;
      }
      .aim-footer a { color: #88a8ff; }
    </style>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
