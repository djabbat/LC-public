<!DOCTYPE html>
<html lang={Atom.to_string(assigns[:locale] || :en)} dir={if AimWeb.I18n.rtl?(assigns[:locale] || :en), do: "rtl", else: "ltr"}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={Plug.CSRFProtection.get_csrf_token()} />
    <title><%= AimWeb.I18n.t("app.title", assigns[:locale] || :en) %></title>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
