<!DOCTYPE html>
<html lang="en" class="h-full bg-zinc-50">
  <head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <meta name="csrf-token" content={Phoenix.Controller.get_csrf_token()}/>
    <.live_title suffix=" · Ze Frontend">
      <%= assigns[:page_title] || "Ze Theory Dashboard" %>
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"}/>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}></script>
  </head>
  <body class="h-full">
    <nav class="bg-white shadow-sm border-b border-zinc-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex">
            <div class="flex-shrink-0 flex items-center">
              <span class="text-xl font-bold text-zinc-900">Ze Theory</span>
              <.badge color="blue" class="ml-2">Counter S</.badge>
            </div>
            <div class="hidden sm:ml-6 sm:flex sm:space-x-8">
              <.link
                navigate={~p"/"}
                class={["border-transparent text-zinc-500 hover:text-zinc-700 hover:border-zinc-300 inline-flex items-center px-1 pt-1 border-b-2 text-sm font-medium", @current_page == :dashboard && "border-blue-500 text-zinc-900"]}
              >
                Dashboard
              </.link>
            </div>
          </div>
        </div>
      </div>
    </nav>
    <main class="max-w-7xl mx-auto py-6 sm:px-6 lg:px-8">
      <%= @inner_content %>
    </main>
    <.telemetry_banner />
  </body>
</html>